{
  "manifest_version": 2,
  "name": "AI Translator",
  "version": "1.0",
  "description": "선택한 영어 텍스트를 AI로 번역합니다",

  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "https://api.anthropic.com/*"
  ],

  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "AI Translator 설정"
  },

  "background": {
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
